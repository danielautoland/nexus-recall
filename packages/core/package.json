{
  "name": "@nexus-recall/core",
  "version": "0.1.0",
  "description": "Reusable core library: vault loader, BM25 index, save_memory. Used by the daemon and the Mac-app.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
