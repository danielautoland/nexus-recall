{
  "name": "@nexus-recall/daemon",
  "version": "0.1.0",
  "description": "MCP server exposing recall + load_memory over a markdown vault.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "nexus-recall": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check:types": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:telemetry": "tsx scripts/telemetry-smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
